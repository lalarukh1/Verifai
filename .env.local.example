# Anthropic (Claude API)
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Apify (Instagram + TikTok + YouTube scraping)
# Get from: https://apify.com → Settings → Integrations → API token
APIFY_API_KEY=your_apify_api_key_here

# Deepgram (audio transcription)
# Get from: https://deepgram.com → Dashboard → API Keys
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Upstash Redis (rate limiting — 5 req/min per IP)
# Get from: https://upstash.com → Create Redis database → REST API section
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# Serper.dev (real-time Google News search for claim sources)
# Get from: https://serper.dev → Dashboard → API Key
# Free tier: 2,500 queries/month, no credit card required
SERPER_API_KEY=your_serper_api_key_here
